# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=attendance_system

# Server Configuration
PORT=3001

# ========================================
# Geolocation Configuration (Phase 2)
# ========================================

# DEVELOPMENT: Home Location (for testing from home)
# Replace with your home coordinates for testing
CAMPUS_LATITUDE=3.0709795053170406
CAMPUS_LONGITUDE=101.56627247844794
CAMPUS_RADIUS=500

# PRODUCTION: University Campus (uncomment when deploying)
# Replace with your university's coordinates for production
# CAMPUS_LATITUDE=3.0673419209015633
# CAMPUS_LONGITUDE=101.6037889559458
# CAMPUS_RADIUS=500

# Note: To switch between locations:
# 1. Comment out the active location (add # at start of line)
# 2. Uncomment the location you want to use (remove # at start of line)
# 3. Restart the backend server (npm run dev)
